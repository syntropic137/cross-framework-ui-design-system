# Supply-chain hardening: block ALL dependency lifecycle scripts
# (preinstall/install/postinstall) across the entire tree, including transitive
# deps. A compromised or malicious package cannot execute code on install.
#
# This is the strongest defense against postinstall-hook attacks
# (event-stream 2018, ua-parser-js 2021). Explicit `pnpm run <script>` from
# this project's own package.json is unaffected — only automatic lifecycle
# scripts during install are blocked.
ignore-scripts=true
