{
  "name": "react-component-library-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@9.1.4",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "build": "pnpm --filter @syntropic137/design-tokens tokens:build && pnpm -r build",
    "test:verify": "node --test scripts/verify-design-system.test.mjs",
    "qa": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm design-system:verify && pnpm test:verify && pnpm storybook:test",
    "check": "pnpm qa",
    "storybook": "pnpm --filter @syntropic137/default-react-v18 storybook",
    "storybook:build": "pnpm --filter @syntropic137/default-react-v18 storybook:build",
    "storybook:test": "pnpm --filter @syntropic137/default-react-v18 storybook:test",
    "storybook:svelte": "pnpm --filter @syntropic137/default-svelte-v5 storybook",
    "test:svelte": "pnpm --filter @syntropic137/default-svelte-v5 test",
    "generate:component": "pnpm --filter @syntropic137/component-generator build && node packages/dev-tools/component-generator/dist/cli.js",
    "tui": "node --experimental-strip-types --disable-warning=ExperimentalWarning packages/dev-tools/dashboard/src/cli.ts",
    "design-system:verify": "node scripts/verify-design-system.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "publish:packages": "pnpm -r publish --access public --provenance --no-git-checks"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-storybook": "^10.4.4",
    "globals": "^17.6.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "esbuild@<0.25.0": ">=0.25.0",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6"
    }
  }
}
