{
  "name": "@design-system/component-generator",
  "version": "0.1.0",
  "description": "CLI tool for generating design system components",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "generate-component": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "handlebars": "^4.7.9",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.8.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.6"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "design-system",
    "component-generator",
    "cli",
    "react",
    "typescript"
  ],
  "author": "Design System Team",
  "license": "MIT"
}
