{
  "name": "@design-system/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rimraf dist generated",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "tokens:build": "pnpm build && node ./dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.4",
    "vitest": "^3.2.6"
  }
}
