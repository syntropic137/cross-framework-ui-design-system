{
  "name": "@syntropic137/design-tokens",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && node ./dist/cli.js",
    "clean": "rimraf dist generated",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "tokens:build": "pnpm build && node ./dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.4",
    "vitest": "^4.1.8",
    "eslint": "^9.39.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generated/design-tokens.css": "./generated/design-tokens.css",
    "./generated/design-tokens.json": "./generated/design-tokens.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntropic137/cross-framework-ui-design-system.git",
    "directory": "packages/design-tokens"
  },
  "license": "MIT"
}
