{
  "name": "@design-system/react-v18",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/design-system"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --build tsconfig.build.json && vite build",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts?(x)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts?(x)\"",
    "storybook": "pnpm --filter @design-system/design-tokens tokens:build && storybook dev --config-dir .storybook --port 6006",
    "storybook:build": "pnpm --filter @design-system/design-tokens tokens:build && storybook build --config-dir .storybook",
    "storybook:test": "pnpm --filter @design-system/design-tokens tokens:build && start-server-and-test \"storybook dev --config-dir .storybook --port 6006 --quiet --ci --no-open\" http://127.0.0.1:6006 \"test-storybook --config-dir .storybook\""
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@design-system/design-tokens": "workspace:^",
    "@playwright/test": "1.55.1",
    "@storybook/jest": "^0.2.3",
    "@storybook/react-vite": "^9.1.20",
    "@storybook/test-runner": "^0.23.0",
    "@storybook/testing-library": "0.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^4.3.2",
    "cross-env": "7.0.3",
    "detect-package-manager": "3.0.1",
    "jsdom": "^24.1.0",
    "prettier": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.7",
    "start-server-and-test": "2.0.2",
    "storybook": "^9.1.20",
    "typescript": "^5.9.2",
    "vite": "^5.4.21",
    "vitest": "^3.2.6",
    "eslint-plugin-storybook": "9.1.20",
    "@storybook/addon-docs": "^9.1.20"
  }
}
