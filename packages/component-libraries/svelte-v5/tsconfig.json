{
  "compilerOptions": {
    "target":               "ES2022",
    "module":               "NodeNext",
    "moduleResolution":     "NodeNext",
    "strict":               true,
    "declaration":          true,
    "declarationMap":       true,
    "sourceMap":            true,
    "esModuleInterop":      true,
    "skipLibCheck":         true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
